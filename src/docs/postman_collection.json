{
  "info": {
    "name": "BBYO Connect API",
    "_postman_id": "8f56bfd6-3f98-4fcb-bf68-ae70f4792af8",
    "description": "Production backend collection for BBYO Connect",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "storyId", "value": "" },
    { "key": "conversationId", "value": "" },
    { "key": "messageId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "chapterId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "approvalId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "register-1" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountType\": \"teen\",\n  \"email\": \"teen@bbyo.org\",\n  \"memberId\": \"TEEN-1000\",\n  \"password\": \"ChangeMe123!\",\n  \"profile\": {\n    \"fullName\": \"Demo Teen\",\n    \"languages\": [\"en\", \"es\"],\n    \"interests\": [\"leadership\"]\n  }\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "login-1" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberIdOrEmail\": \"TEEN-1000\",\n  \"password\": \"ChangeMe123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Guest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "guest-1" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"locale\": \"en\"\n}"
            },
            "url": "{{baseUrl}}/auth/guest"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "refresh-1" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Verification",
      "item": [
        {
          "name": "Create Vouch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Idempotency-Key", "value": "vouch-1" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"targetUserId\": \"target-user-id\"\n}" },
            "url": "{{baseUrl}}/verification/vouches"
          }
        },
        {
          "name": "Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/verification/status"
          }
        }
      ]
    },
    {
      "name": "Chapter Approvals",
      "item": [
        {
          "name": "Request Approval",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Please review chapter account\"\n}" },
            "url": "{{baseUrl}}/chapter-approvals/request"
          }
        },
        {
          "name": "Approve",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Approved\"\n}" },
            "url": "{{baseUrl}}/chapter-approvals/{{approvalId}}/approve"
          }
        },
        {
          "name": "Reject",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Rejected\"\n}" },
            "url": "{{baseUrl}}/chapter-approvals/{{approvalId}}/reject"
          }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "List Feed",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/feed?limit=20"
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"general\",\n  \"text\": \"Hello BBYO!\",\n  \"language\": \"en\",\n  \"visibility\": \"global\",\n  \"media\": []\n}"
            },
            "url": "{{baseUrl}}/feed"
          }
        },
        {
          "name": "Get Post",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/feed/{{postId}}"
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Updated post\"\n}" },
            "url": "{{baseUrl}}/feed/{{postId}}"
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/feed/{{postId}}"
          }
        },
        {
          "name": "React",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reactionType\": \"like\"\n}" },
            "url": "{{baseUrl}}/feed/{{postId}}/reactions"
          }
        },
        {
          "name": "Remove Reaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/feed/{{postId}}/reactions"
          }
        },
        {
          "name": "List Comments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/feed/{{postId}}/comments"
          }
        },
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Great post\",\n  \"language\": \"en\"\n}" },
            "url": "{{baseUrl}}/feed/{{postId}}/comments"
          }
        }
      ]
    },
    {
      "name": "Stories",
      "item": [
        {
          "name": "List Stories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/stories"
          }
        },
        {
          "name": "Create Story",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"mediaUrl\": \"https://cdn.example.com/story.jpg\",\n  \"expiresInHours\": 24\n}" },
            "url": "{{baseUrl}}/stories"
          }
        },
        {
          "name": "Delete Story",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/stories/{{storyId}}"
          }
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        { "name": "List Conversations", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/messages/conversations" } },
        {
          "name": "Create Conversation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"private\",\n  \"memberIds\": [\"user-2\"],\n  \"title\": \"Chat\"\n}" },
            "url": "{{baseUrl}}/messages/conversations"
          }
        },
        { "name": "List Messages", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/messages" } },
        {
          "name": "Create Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Hello\",\n  \"contentType\": \"text\",\n  \"attachments\": []\n}" },
            "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/messages"
          }
        },
        {
          "name": "Edit Message",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Edited message\"\n}" },
            "url": "{{baseUrl}}/messages/messages/{{messageId}}"
          }
        },
        { "name": "Delete Message", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/messages/messages/{{messageId}}" } },
        { "name": "Read Receipt", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/messages/messages/{{messageId}}/read" } }
      ]
    },
    {
      "name": "Events",
      "item": [
        { "name": "List Events", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/events" } },
        { "name": "Get Event", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/events/{{eventId}}" } },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Global Meetup\",\n  \"description\": \"Cross-chapter event\",\n  \"startAt\": \"2026-06-01T18:00:00.000Z\",\n  \"endAt\": \"2026-06-01T20:00:00.000Z\",\n  \"timezone\": \"UTC\",\n  \"visibility\": \"public\",\n  \"isVirtual\": true\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Global Meetup\"\n}" },
            "url": "{{baseUrl}}/events/{{eventId}}"
          }
        },
        { "name": "Delete Event", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/events/{{eventId}}" } },
        { "name": "Register Event", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/events/{{eventId}}/register" } },
        { "name": "Unregister Event", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/events/{{eventId}}/register" } },
        {
          "name": "Event Reminder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"remindAt\": \"2026-06-01T17:00:00.000Z\"\n}" },
            "url": "{{baseUrl}}/events/{{eventId}}/reminders"
          }
        }
      ]
    },
    {
      "name": "Chapters",
      "item": [
        { "name": "List Chapters", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/chapters" } },
        { "name": "Map Pins", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/chapters/map-pins" } },
        { "name": "Chapter Detail", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/chapters/{{chapterId}}" } },
        { "name": "Chapter Board", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/chapters/{{chapterId}}/board" } },
        { "name": "Chapter Projects", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/chapters/{{chapterId}}/projects" } },
        {
          "name": "Travel Intro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"Visiting your chapter this summer!\"\n}" },
            "url": "{{baseUrl}}/chapters/{{chapterId}}/travel-intro"
          }
        }
      ]
    },
    {
      "name": "Resources and Gamification",
      "item": [
        { "name": "List Resources", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/resources?language=en" } },
        {
          "name": "Create Resource",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Youth Leadership 101\",\n  \"type\": \"article\",\n  \"language\": \"en\",\n  \"url\": \"https://example.org/resource\",\n  \"visibility\": \"global\"\n}" },
            "url": "{{baseUrl}}/resources"
          }
        },
        { "name": "Leaderboard", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/gamification/leaderboard?scope=global&period=weekly" } },
        { "name": "My Gamification", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/gamification/me" } }
      ]
    },
    {
      "name": "Reports and Notifications",
      "item": [
        {
          "name": "Create Report",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"targetType\": \"post\",\n  \"targetId\": \"{{postId}}\",\n  \"reason\": \"Unsafe language\",\n  \"details\": \"Possible harassment\"\n}" },
            "url": "{{baseUrl}}/reports"
          }
        },
        { "name": "List Reports", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/reports?status=open" } },
        {
          "name": "Resolve Report",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"resolved\",\n  \"actionType\": \"hide_content\",\n  \"notes\": \"Hidden pending follow-up\"\n}" },
            "url": "{{baseUrl}}/reports/{{reportId}}/resolve"
          }
        },
        { "name": "List Notifications", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/notifications" } },
        { "name": "Read Notification", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/notifications/{{notificationId}}/read" } }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "Presign Upload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fileName\": \"voice-note.m4a\",\n  \"contentType\": \"audio/mp4\",\n  \"sizeBytes\": 550000\n}" },
            "url": "{{baseUrl}}/uploads/presign"
          }
        }
      ]
    }
  ]
}
