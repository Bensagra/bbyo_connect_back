DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bbyo_connect?schema=public"
REDIS_ENABLED="false"
REDIS_URL=""
NODE_ENV="development"
PORT="4000"
ACCESS_TOKEN_SECRET="replace-with-strong-access-secret"
REFRESH_TOKEN_SECRET="replace-with-strong-refresh-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"
CORS_ALLOWLIST="http://localhost:3000,http://localhost:5173"
IDEMPOTENCY_TTL_SECONDS="300"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_IP="120"
RATE_LIMIT_MAX_USER="240"
BANNED_WORDS="hateword1,hateword2"
UPLOAD_SIGNING_SECRET="replace-with-upload-signing-secret"
JWT_ISSUER="bbyo-connect-api"
