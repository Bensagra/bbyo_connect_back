{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "module": "commonjs",
    "target": "es2022",
    "types": ["node", "jest"],
    "lib": ["es2022"],
    "sourceMap": true,
    "declaration": false,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src", "api", "tests", "prisma/seed.ts"],
  "exclude": ["dist", "node_modules"]
}
